# Default text-file normalization
* text=auto

# Backend and application source code
*.py       text eol=lf
*.pyi      text eol=lf
*.toml     text eol=lf
*.ini      text eol=lf

# Infrastructure and container configuration
Dockerfile text eol=lf
*.dockerfile text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.conf     text eol=lf
*.sh       text eol=lf

# Frontend source code
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.json     text eol=lf
*.css      text eol=lf
*.html     text eol=lf

# Documentation and environment templates
*.md       text eol=lf
*.example  text eol=lf

# Windows PowerShell scripts
*.ps1      text eol=crlf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
